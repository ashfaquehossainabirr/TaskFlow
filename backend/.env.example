# MongoDB connection string
# Local example: mongodb://127.0.0.1:27017/taskflow
# Atlas example: mongodb+srv://<user>:<password>@cluster.mongodb.net/taskflow
MONGO_URI=mongodb://127.0.0.1:27017/taskflow

# Secret used to sign JWT auth tokens - change this to a long random string
JWT_SECRET=change_this_to_a_long_random_secret_string

# How long a login session stays valid
JWT_EXPIRES_IN=7d

# Port the API server listens on
PORT=5000

# Comma separated list of origins allowed to call this API
CLIENT_URL=http://localhost:5173

# Used only by `npm run seed` to create the first admin account
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_EMAIL=admin@taskflow.com
SEED_ADMIN_PASSWORD=Admin@12345

# --- Deadline reminder emails ---
# SMTP credentials used to send the daily deadline reminder emails.
# Example for Gmail: host smtp.gmail.com, port 587, secure false,
# and EMAIL_PASS must be a 16-character Gmail "App Password" (not your login password).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=TaskFlow <your_email@gmail.com>

# Cron expression for when the reminder job runs. Default = every day at 10:00.
REMINDER_CRON=0 10 * * *
# Timezone the cron expression above is evaluated in.
REMINDER_TIMEZONE=UTC
# Tasks with this many days (or fewer) left until their deadline get included in the email.
REMINDER_DAYS_THRESHOLD=3

# Set to false if you're using an external scheduler (e.g. cron-job.org) to call
# /api/cron/deadline-reminder instead of relying on the built-in node-cron timer.
# Recommended: false on Render's free tier, since a sleeping service can miss the internal timer.
ENABLE_INTERNAL_CRON=true

# Shared secret required in the "x-cron-secret" header to call POST /api/cron/deadline-reminder.
# Generate any long random string - this is NOT your email password.
CRON_SECRET=change_this_to_a_long_random_string
